---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { characters, blogMeta, teamLabels } from '../data/characters';

const founder  = characters.find(c => c.team === 'founder')!;
const manager  = characters.find(c => c.team === 'manager')!;
const teamA    = characters.filter(c => c.team === 'teamA');
const teamB    = characters.filter(c => c.team === 'teamB');
const cross    = characters.filter(c => c.team === 'cross');
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title="組織図 | バリュー商会" description="バリュー商会の組織図" />
  </head>
  <body>
    <Header />
    <main>
      <!-- サイトタイトル -->
      <div class="org-title">
        <h1>バリュー商会</h1>
        <p class="subtitle">割安日本個別株・TOB発掘・競合優位性・インカム運用</p>
        <p class="tagline">インデックスに物足りない、でも米株はどのリスクは怖い——その中間地帯のための投資記録</p>
      </div>

      <div class="org-chart">

        <!-- FOUNDER -->
        <div class="tier">
          <div class="tier-label">FOUNDER</div>
          <div class="cards-row single">
            <div class="card card-founder">
              <div class="card-avatar" style={`background:${founder.avatarColor}`}>{founder.emoji}</div>
              <div class="card-content">
                <div class="card-name-row">
                  <span class="card-name">{founder.name}</span>
                  <span class="card-species">{founder.species}</span>
                </div>
                <p class="card-catch">{founder.catchphrase}</p>
                <blockquote>「{founder.quote}」</blockquote>
                <div class="tags">{founder.tags.map(t => <span class="tag">{t}</span>)}</div>
              </div>
            </div>
          </div>
        </div>

        <div class="connector"><div class="line"></div></div>

        <!-- MANAGER -->
        <div class="tier">
          <div class="tier-label">MANAGER</div>
          <div class="cards-row single">
            <div class="card card-manager">
              <div class="card-avatar" style={`background:${manager.avatarColor}`}>{manager.emoji}</div>
              <div class="card-content">
                <div class="card-name-row">
                  <span class="card-name">{manager.name}</span>
                  <span class="card-species">{manager.species}</span>
                </div>
                <p class="card-catch">{manager.catchphrase}</p>
                <blockquote>「{manager.quote}」</blockquote>
                <div class="tags">{manager.tags.map(t => <span class="tag">{t}</span>)}</div>
              </div>
            </div>
          </div>
        </div>

        <div class="connector"><div class="line"></div></div>

        <!-- TEAM A -->
        <div class="tier">
          <div class="tier-label">TEAM A — {teamLabels['teamA']}</div>
          <div class="cards-row multi">
            {teamA.map(c => (
              <div class="card card-member">
                <div class="card-avatar sm" style={`background:${c.avatarColor}`}>{c.emoji}</div>
                <div class="card-content">
                  <div class="card-name-row">
                    <span class="card-name sm">{c.name}</span>
                    <span class="card-species">{c.title} ／ {c.species.split('／')[0]}</span>
                  </div>
                  <p class="card-catch sm">{c.catchphrase}</p>
                  <blockquote class="sm">「{c.quote}」</blockquote>
                  <div class="tags">{c.tags.map(t => <span class="tag">{t}</span>)}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="connector"><div class="line"></div></div>

        <!-- TEAM B -->
        <div class="tier">
          <div class="tier-label">TEAM B — {teamLabels['teamB']}</div>
          <div class="cards-row multi">
            {teamB.map(c => (
              <div class="card card-member">
                <div class="card-avatar sm" style={`background:${c.avatarColor}`}>{c.emoji}</div>
                <div class="card-content">
                  <div class="card-name-row">
                    <span class="card-name sm">{c.name}</span>
                    <span class="card-species">{c.title} ／ {c.species.split('／')[0]}</span>
                  </div>
                  <p class="card-catch sm">{c.catchphrase}</p>
                  <blockquote class="sm">「{c.quote}」</blockquote>
                  <div class="tags">{c.tags.map(t => <span class="tag">{t}</span>)}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="connector"><div class="line"></div></div>

        <!-- CROSS -->
        {cross.map(c => (
          <div class="tier">
            <div class="tier-label cross-label">CROSS 横断</div>
            <div class="cards-row single">
              <div class="card card-cross">
                <div class="card-avatar sm" style={`background:${c.avatarColor}`}>{c.emoji}</div>
                <div class="card-content">
                  <div class="card-name-row">
                    <span class="card-name">{c.name}</span>
                    <span class="card-species">{c.title} ／ {c.species}</span>
                  </div>
                  <p class="card-catch">{c.catchphrase}</p>
                  <blockquote>「{c.quote}」</blockquote>
                  <div class="tags">{c.tags.map(t => <span class="tag">{t}</span>)}</div>
                </div>
              </div>
            </div>
          </div>
        ))}

        <!-- RIVALS -->
        <div class="tier rivals-tier">
          <div class="tier-label rivals-label">RIVALS</div>
          <div class="cards-row multi rivals-row">
            {blogMeta.rivals.map(r => (
              <div class="card card-rival">
                <div class="rival-header">
                  <span class="rival-emoji">{r.emoji}</span>
                  <div>
                    <div class="card-name sm">{r.name}</div>
                    <div class="card-species">{r.subtitle}</div>
                  </div>
                </div>
                <div class="rival-members">
                  {r.members.map(m => <span class="rival-member">{m}</span>)}
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2em 1em 4em;
  }

  /* タイトル */
  .org-title {
    text-align: center;
    margin-bottom: 2.5em;
  }
  .org-title h1 {
    font-size: 2em;
    color: var(--accent-dark);
    margin-bottom: 0.2em;
  }
  .subtitle {
    font-size: 0.85em;
    color: rgb(var(--gray));
    margin: 0.1em 0;
  }
  .tagline {
    font-size: 0.8em;
    color: rgb(var(--gray));
    margin: 0.2em 0 0;
  }

  /* 組織図全体 */
  .org-chart {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* コネクター */
  .connector {
    display: flex;
    justify-content: center;
    height: 32px;
  }
  .connector .line {
    width: 2px;
    height: 100%;
    background: #ccc;
  }

  /* 各段 */
  .tier {
    width: 100%;
  }
  .tier-label {
    text-align: center;
    font-size: 0.72em;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgb(var(--gray));
    margin-bottom: 0.6em;
    text-transform: uppercase;
  }
  .cross-label { color: #1D9E75; }
  .rivals-label { color: #999; }

  /* カード行 */
  .cards-row {
    display: flex;
    justify-content: center;
    gap: 1em;
    flex-wrap: wrap;
  }
  .cards-row.single .card {
    width: min(480px, 100%);
  }
  .cards-row.multi {
    align-items: stretch;
  }
  .cards-row.multi .card {
    flex: 1 1 180px;
    max-width: 220px;
  }
  .rivals-row .card {
    flex: 1 1 260px;
    max-width: 340px;
  }

  /* カード基本 */
  .card {
    background: white;
    border: 1.5px solid #e0e0e0;
    border-radius: 10px;
    padding: 1em 1.1em;
    display: flex;
    flex-direction: column;
    gap: 0.6em;
    box-shadow: 0 1px 4px rgba(0,0,0,5%);
  }
  .card-founder { border-color: var(--accent); border-width: 2px; }
  .card-manager { border-color: #6ba4d4; border-width: 2px; }
  .card-cross   { border-color: var(--accent); border-style: dashed; width: min(640px, 100%); }
  .card-rival   { border: 2px dashed #ccc; background: #fafafa; }

  /* アバター */
  .card-avatar {
    font-size: 2em;
    width: 2.2em;
    height: 2.2em;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    align-self: flex-start;
  }
  .card-avatar.sm {
    font-size: 1.6em;
    width: 2em;
    height: 2em;
  }

  /* カード内テキスト */
  .card-content { flex: 1; }
  .card-name-row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5em;
    margin-bottom: 0.3em;
  }
  .card-name {
    font-size: 1.05em;
    font-weight: 700;
    color: rgb(var(--black));
  }
  .card-name.sm { font-size: 0.95em; }
  .card-species {
    font-size: 0.75em;
    color: rgb(var(--gray));
  }
  .card-catch {
    font-size: 0.8em;
    color: rgb(var(--gray-dark));
    margin: 0 0 0.4em;
    line-height: 1.5;
  }
  .card-catch.sm { font-size: 0.75em; }

  blockquote {
    border-left: 3px solid var(--accent);
    padding: 0.2em 0 0.2em 0.7em;
    margin: 0 0 0.5em;
    font-size: 0.82em;
    font-style: italic;
    color: rgb(var(--gray-dark));
  }
  blockquote.sm { font-size: 0.78em; }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3em;
  }
  .tag {
    background: var(--accent-light);
    color: var(--accent-dark);
    font-size: 0.7em;
    padding: 0.15em 0.55em;
    border-radius: 4px;
    font-weight: 600;
  }

  /* ライバル */
  .rivals-tier { margin-top: 1.5em; }
  .rival-header {
    display: flex;
    align-items: center;
    gap: 0.6em;
    margin-bottom: 0.5em;
  }
  .rival-emoji { font-size: 1.6em; }
  .rival-members {
    display: flex;
    gap: 0.5em;
    flex-wrap: wrap;
  }
  .rival-member {
    font-size: 0.78em;
    color: rgb(var(--gray));
    background: #f0f0f0;
    padding: 0.15em 0.5em;
    border-radius: 4px;
  }

  @media (max-width: 720px) {
    .cards-row.multi .card { max-width: 100%; flex-basis: 100%; }
    .rivals-row .card { max-width: 100%; flex-basis: 100%; }
  }
</style>
