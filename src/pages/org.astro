---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { characters, rivalOrgs, teamLabels } from '../data/characters';

const founder = characters.find(c => c.team === 'founder')!;
const manager = characters.find(c => c.team === 'manager')!;
const teamA   = characters.filter(c => c.team === 'teamA');
const teamB   = characters.filter(c => c.team === 'teamB');
const cross   = characters.filter(c => c.team === 'cross');
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title="組織図 | バリュー商会" description="バリュー商会の組織図" />
  </head>
  <body>
    <Header />
    <main>
      <div class="org-title">
        <h1>バリュー商会</h1>
        <p class="subtitle">割安日本個別株・TOB発掘・競合優位性・インカム運用</p>
        <p class="tagline">インデックスに物足りない、でも米株はどのリスクは怖い——その中間地帯のための投資記録</p>
      </div>

      <div class="org-chart">

        <!-- FOUNDER -->
        <div class="tier">
          <div class="tier-label">FOUNDER</div>
          <div class="row row-single">
            <a href={`/characters#${founder.id}`} class="card-link">
            <div class="card card-founder">
              <div class="avatar" style={`background:${founder.avatarColor}`}>{founder.emoji}</div>
              <div class="body">
                <div class="name-row"><strong>{founder.name}</strong><span class="species">{founder.species}</span></div>
                <p class="catch">{founder.catchphrase}</p>
                <blockquote>「{founder.quote}」</blockquote>
                <div class="tags">{founder.tags.map(t => <span class="tag">{t}</span>)}</div>
              </div>
            </div>
            </a>
          </div>
        </div>

        <div class="connector"><div class="line"></div></div>

        <!-- MANAGER -->
        <div class="tier">
          <div class="tier-label">MANAGER</div>
          <div class="row row-single">
            <a href={`/characters#${manager.id}`} class="card-link">
            <div class="card card-manager">
              <div class="avatar" style={`background:${manager.avatarColor}`}>{manager.emoji}</div>
              <div class="body">
                <div class="name-row"><strong>{manager.name}</strong><span class="species">{manager.species}</span></div>
                <p class="catch">{manager.catchphrase}</p>
                <blockquote>「{manager.quote}」</blockquote>
                <div class="tags">{manager.tags.map(t => <span class="tag">{t}</span>)}</div>
              </div>
            </div>
            </a>
          </div>
        </div>

        <div class="connector"><div class="line"></div></div>

        <!-- TEAM A : 4枚横並び -->
        <div class="tier">
          <div class="tier-label">TEAM A — {teamLabels['teamA']}</div>
          <div class="row row-4">
            {teamA.map(c => (
              <a href={`/characters#${c.id}`} class="card-link">
              <div class="card card-sm">
                <div class="avatar sm" style={`background:${c.avatarColor}`}>{c.emoji}</div>
                <div class="body">
                  <div class="name-row"><strong class="sm">{c.name}</strong><span class="species">{c.title}</span></div>
                  <p class="catch sm">{c.catchphrase}</p>
                  <blockquote class="sm">「{c.quote}」</blockquote>
                  <div class="tags">{c.tags.map(t => <span class="tag">{t}</span>)}</div>
                </div>
              </div>
              </a>
            ))}
          </div>
        </div>

        <div class="connector"><div class="line"></div></div>

        <!-- TEAM B (3枚) + CROSS (1枚) 横並び -->
        <div class="tier">
          <div class="tier-label-group">
            <span class="tier-label inline">TEAM B — {teamLabels['teamB']}</span>
            <span class="tier-label-sep">／</span>
            <span class="tier-label inline cross-label">CROSS 横断</span>
          </div>
          <div class="row row-4">
            {teamB.map(c => (
              <a href={`/characters#${c.id}`} class="card-link">
              <div class="card card-sm">
                <div class="avatar sm" style={`background:${c.avatarColor}`}>{c.emoji}</div>
                <div class="body">
                  <div class="name-row"><strong class="sm">{c.name}</strong><span class="species">{c.title}</span></div>
                  <p class="catch sm">{c.catchphrase}</p>
                  <blockquote class="sm">「{c.quote}」</blockquote>
                  <div class="tags">{c.tags.map(t => <span class="tag">{t}</span>)}</div>
                </div>
              </div>
              </a>
            ))}
            {cross.map(c => (
              <a href={`/characters#${c.id}`} class="card-link">
              <div class="card card-sm card-cross">
                <div class="avatar sm" style={`background:${c.avatarColor}`}>{c.emoji}</div>
                <div class="body">
                  <div class="name-row"><strong class="sm">{c.name}</strong><span class="species">{c.title}</span></div>
                  <p class="catch sm">{c.catchphrase}</p>
                  <blockquote class="sm">「{c.quote}」</blockquote>
                  <div class="tags">{c.tags.map(t => <span class="tag">{t}</span>)}</div>
                </div>
              </div>
              </a>
            ))}
          </div>
        </div>

        <!-- RIVALS -->
        <div class="tier rivals-tier">
          <div class="tier-label rivals-label">⚔️ RIVALS — 過去の自分であり好敵手</div>
          <div class="row row-rivals">
            {rivalOrgs.map(org => (
              <div class="card card-rival">
                <div class="rival-head">
                  <span class="rival-emoji">{org.emoji}</span>
                  <div>
                    <strong class="sm">{org.name}</strong>
                    <div class="species">{org.subtitle}</div>
                    <div class="rival-tagline">{org.tagline}</div>
                  </div>
                </div>
                <p class="rival-past">{org.pastSelf}</p>
                <div class="rival-chips">
                  {org.members.map(m => (
                    <span class="rival-chip">
                      {m.emoji} {m.name}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 2em 1em 4em;
    font-size: 14px;
  }

  /* タイトル */
  .org-title {
    text-align: center;
    margin-bottom: 2em;
  }
  .org-title h1 { font-size: 1.8em; color: var(--accent-dark); margin-bottom: 0.2em; }
  .subtitle  { font-size: 0.8em; color: rgb(var(--gray)); margin: 0.1em 0; }
  .tagline   { font-size: 0.75em; color: rgb(var(--gray)); margin: 0.2em 0 0; }

  /* 組織図 */
  .org-chart { display: flex; flex-direction: column; align-items: center; gap: 0; }

  /* コネクター */
  .connector { display: flex; justify-content: center; height: 24px; }
  .connector .line { width: 2px; height: 100%; background: #ccc; }

  /* 各段 */
  .tier { width: 100%; margin-bottom: 0; }

  .tier-label {
    text-align: center;
    font-size: 0.65em;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgb(var(--gray));
    text-transform: uppercase;
    margin-bottom: 0.5em;
  }
  .tier-label-group {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4em;
    margin-bottom: 0.5em;
  }
  .tier-label.inline { margin-bottom: 0; }
  .tier-label-sep { font-size: 0.65em; color: rgb(var(--gray)); }
  .cross-label { color: var(--accent); }
  .rivals-label { color: #999; }

  /* カード行 */
  .row { display: flex; justify-content: center; gap: 0.7em; }
  .row-single .card { width: 100%; }
  .row-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.7em; width: 100%; }
  .row-rivals { gap: 0.7em; }
  .row-rivals .card { flex: 1 1 220px; max-width: 320px; }

  /* カードリンク */
  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, box-shadow 0.15s;
    border-radius: 8px;
  }
  .card-link:hover { transform: translateY(-2px); }
  .card-link:hover .card { box-shadow: 0 4px 12px rgba(0,0,0,12%); border-color: var(--accent); }
  .row-single .card-link { width: min(400px, 100%); }

  /* カード基本 */
  .card {
    background: white;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    padding: 0.7em 0.8em;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
    box-shadow: 0 1px 3px rgba(0,0,0,5%);
  }
  .card-founder { border-color: var(--accent); border-width: 2px; }
  .card-manager { border-color: #6ba4d4; border-width: 2px; }
  .card-cross   { border-color: var(--accent); border-style: dashed; }
  .card-rival   { border: 1.5px dashed #ccc; background: #fafafa; }

  /* アバター */
  .avatar {
    font-size: 1.6em;
    width: 2em; height: 2em;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; align-self: flex-start;
  }
  .avatar.sm { font-size: 1.3em; }

  /* カード内テキスト */
  .body { flex: 1; }
  .name-row {
    display: flex; align-items: baseline; flex-wrap: wrap; gap: 0.4em;
    margin-bottom: 0.25em;
  }
  strong      { font-size: 0.95em; color: rgb(var(--black)); }
  strong.sm   { font-size: 0.88em; }
  .species    { font-size: 0.7em; color: rgb(var(--gray)); }
  .catch      { font-size: 0.75em; color: rgb(var(--gray-dark)); margin: 0 0 0.3em; line-height: 1.4; }
  .catch.sm   { font-size: 0.7em; }

  blockquote {
    border-left: 2px solid var(--accent);
    padding: 0.15em 0 0.15em 0.6em;
    margin: 0 0 0.4em;
    font-size: 0.75em;
    font-style: italic;
    color: rgb(var(--gray-dark));
  }
  blockquote.sm { font-size: 0.7em; }

  .tags { display: flex; flex-wrap: wrap; gap: 0.25em; }
  .tag {
    background: var(--accent-light);
    color: var(--accent-dark);
    font-size: 0.65em;
    padding: 0.12em 0.45em;
    border-radius: 3px;
    font-weight: 600;
  }

  /* ライバル */
  .rivals-tier { margin-top: 1.5em; }
  .rivals-label { font-size: 0.7em; color: #888; }
  .row-rivals { gap: 0.7em; width: 100%; }
  .row-rivals .card { flex: 1 1 0; }
  .rival-head { display: flex; align-items: flex-start; gap: 0.5em; margin-bottom: 0.5em; }
  .rival-emoji { font-size: 1.6em; flex-shrink: 0; margin-top: 0.1em; }
  .rival-tagline { font-size: 0.66em; color: rgb(var(--gray)); font-style: italic; margin-top: 0.15em; }
  .rival-past {
    font-size: 0.7em; color: rgb(var(--gray)); line-height: 1.55; margin: 0;
    border-left: 2px solid #ccc; padding-left: 0.5em;
    font-style: italic;
  }
  .rival-chips { display: flex; gap: 0.3em; flex-wrap: wrap; margin-top: 0.2em; }
  .rival-chip {
    font-size: 0.68em; color: rgb(var(--gray-dark));
    background: #ececec; padding: 0.1em 0.5em; border-radius: 3px;
  }

  @media (max-width: 720px) {
    .row-4 { grid-template-columns: repeat(2, 1fr); }
    .row-rivals .card { max-width: 100%; flex-basis: 100%; }
  }
  @media (max-width: 480px) {
    .row-4 { grid-template-columns: 1fr; }
  }
</style>
