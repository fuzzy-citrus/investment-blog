---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 5);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-badge">🏢 バリュー商会</div>
				<h1>沼田課長と愉快な部下たちの<br />投資記録</h1>
				<p class="hero-desc">{SITE_DESCRIPTION}</p>
				<div class="hero-tags">
					<span class="tag">割安日本個別株</span>
					<span class="tag">TOB発掘</span>
					<span class="tag">低PBR</span>
					<span class="tag">高配当・優待</span>
					<span class="tag">ガバナンス改革</span>
				</div>
			</section>

			<section class="about-blog">
				<h2>バリュー商会とは</h2>
				<div class="about-grid">
					<div class="about-item">
						<span class="about-icon">🧑‍💼</span>
						<div>
							<div class="about-label">運営者</div>
							<div class="about-text">保有資産約5,000万円。野村の錬金術士（見習い）こと沼田堅一課長を主人公に、バリュー商会の資産を実際の投資成績と直結させて育てていく実践記録です。</div>
						</div>
					</div>
					<div class="about-item">
						<span class="about-icon">🎯</span>
						<div>
							<div class="about-label">目標</div>
							<div class="about-text"><strong>バリュー商会の資産推移＝筆者本人の運用成績です。</strong>中間目標：2028年に1億円、最終目標：2030年に2億円以上。<br /><span class="about-note-inline">※注目銘柄は紹介しますがポジション全部の公開はしてません。インデックスやテーマ株・モメンタムも時々混ざるのでブレは多少あります。</span></div>
						</div>
					</div>
					<div class="about-item">
						<span class="about-icon">📊</span>
						<div>
							<div class="about-label">投資スタンス</div>
							<div class="about-text">メインはバリュー株・TOB発掘・低PBR。紹介銘柄・戦略は野村証券の口座で実際に売買しながら更新します。</div>
						</div>
					</div>
					<div class="about-item">
						<span class="about-icon">🏦</span>
						<div>
							<div class="about-label">野村の錬金術（低金利レバレッジ）</div>
							<div class="about-text">野村証券の信用金利は<strong>年1.43%</strong>。配当利回りが<strong>1.79%以上</strong>あれば、税金を考慮しても利ザヤでプラスの追加収益が見込めます。そこそこの配当利回りでも<strong>配当性向が低くキャッシュを溜め込んでいるニッチトップ銘柄</strong>なら積極的に集める方針。下値余地が小さく、信用金利を配当で上回れる銘柄を狙い撃ちします。</div>
						</div>
					</div>
				</div>
				<p class="about-note">※このブログは自身の投資手法や成績を振り返り、今後に活かす場所として活用しています。</p>
			</section>

			<div class="theme-pillars">
				<div class="tp-item">
					<svg viewBox="0 0 60 60" class="tp-svg" fill="none" xmlns="http://www.w3.org/2000/svg">
						<circle cx="30" cy="30" r="26" stroke="currentColor" stroke-width="0.8" opacity="0.25"/>
						<path d="M24 26 L21 36 Q16 44 30 44 Q44 44 39 36 L36 26 Z" stroke="currentColor" stroke-width="1.8"/>
						<line x1="23" y1="26" x2="37" y2="26" stroke="currentColor" stroke-width="1.8"/>
						<line x1="25" y1="23" x2="35" y2="23" stroke="currentColor" stroke-width="1.8"/>
						<path d="M17 39 Q17 44 30 44 Q43 44 43 39 Z" fill="currentColor" opacity="0.2"/>
						<polygon points="30,10 32,16 39,16 34,20 36,26 30,23 24,26 26,20 21,16 28,16" fill="currentColor" opacity="0.75"/>
						<circle cx="10" cy="30" r="7" stroke="#c9992a" stroke-width="1.2" opacity="0.75"/>
						<line x1="7" y1="30" x2="13" y2="30" stroke="#c9992a" stroke-width="1" opacity="0.75"/>
						<line x1="10" y1="26" x2="10" y2="34" stroke="#c9992a" stroke-width="1" opacity="0.75"/>
					</svg>
					<span class="tp-title">金融錬金術</span>
					<span class="tp-desc">低金利で借りて<br/>配当で上回る</span>
				</div>
				<div class="tp-item">
					<svg viewBox="0 0 60 60" class="tp-svg" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M30 5 Q40 8 42 18 Q43 28 37 34 Q28 40 19 36 Q11 30 13 20 Q15 10 30 5 Z" stroke="currentColor" stroke-width="1.4" opacity="0.65"/>
						<path d="M21 18 L26 23 M26 18 L21 23" stroke="#c9992a" stroke-width="2.2" stroke-linecap="round" opacity="0.9"/>
						<path d="M32 27 L37 32 M37 27 L32 32" stroke="#c9992a" stroke-width="2.2" stroke-linecap="round" opacity="0.8"/>
						<circle cx="43" cy="46" r="12" stroke="currentColor" stroke-width="1.8"/>
						<line x1="52" y1="55" x2="58" y2="59" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
						<polygon points="43,37 51,45 43,54 35,45" stroke="currentColor" stroke-width="1.2" opacity="0.65"/>
					</svg>
					<span class="tp-title">割安宝探し</span>
					<span class="tp-desc">低PBR・不動産含み益<br/>隠れた価値を掘り出す</span>
				</div>
				<div class="tp-item">
					<svg viewBox="0 0 60 60" class="tp-svg" fill="none" xmlns="http://www.w3.org/2000/svg">
						<polygon points="30,5 8,50 52,50" stroke="currentColor" stroke-width="1.8" opacity="0.72"/>
						<line x1="30" y1="2" x2="30" y2="8" stroke="currentColor" stroke-width="1.8"/>
						<polygon points="30,2 42,6 30,10" fill="currentColor" opacity="0.9"/>
						<circle cx="44" cy="47" r="7" stroke="currentColor" stroke-width="1.5" opacity="0.65"/>
						<circle cx="44" cy="47" r="3" fill="currentColor" opacity="0.5"/>
						<line x1="44" y1="38" x2="44" y2="36" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" opacity="0.65"/>
						<line x1="44" y1="58" x2="44" y2="56" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" opacity="0.65"/>
						<line x1="35" y1="47" x2="33" y2="47" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" opacity="0.65"/>
						<line x1="55" y1="47" x2="53" y2="47" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" opacity="0.65"/>
						<line x1="38" y1="41" x2="36.5" y2="39.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" opacity="0.65"/>
						<line x1="51" y1="54" x2="52.5" y2="55.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" opacity="0.65"/>
						<line x1="38" y1="53" x2="36.5" y2="54.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" opacity="0.65"/>
						<line x1="51" y1="41" x2="52.5" y2="39.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" opacity="0.65"/>
					</svg>
					<span class="tp-title">ニッチトップ応援</span>
					<span class="tp-desc">競合が入れない市場<br/>小さな技術の巨人</span>
				</div>
			</div>

			<section class="asset-status">
				<div class="asset-header">
					<span class="asset-launch-badge">🚀 スタートライン — 2026年5月</span>
					<span class="asset-account">野村証券 実口座</span>
				</div>
				<div class="asset-main">
					<div class="asset-amounts">
						<div class="asset-amt-block">
							<div class="asset-amt-label">現在総資産（2026年5月）</div>
							<div class="asset-amt-val val-now"><strong>4,474万円</strong></div>
							<div class="asset-now-sub">評価損益 <span class="pos">+816万円</span></div>
						</div>
						<div class="asset-amt-arrow">
							<svg viewBox="0 0 48 16" width="48" height="16"><path d="M0 8 L38 8 M30 3 L42 8 L30 13" stroke="rgba(255,255,255,0.3)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
						</div>
						<div class="asset-amt-block">
							<div class="asset-amt-label">中間目標 2028年</div>
							<div class="asset-amt-val val-mid"><strong>1億円</strong></div>
						</div>
						<div class="asset-amt-arrow">
							<svg viewBox="0 0 48 16" width="48" height="16"><path d="M0 8 L38 8 M30 3 L42 8 L30 13" stroke="rgba(255,255,255,0.3)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
						</div>
						<div class="asset-amt-block">
							<div class="asset-amt-label">最終目標 2030年</div>
							<div class="asset-amt-val val-goal"><strong>2億円</strong></div>
						</div>
					</div>
					<div class="asset-bar-wrap">
						<div class="asset-bar">
							<div class="asset-bar-fill" style="width:22.4%">
								<span class="asset-bar-now">NOW<br/>22%</span>
							</div>
							<div class="asset-bar-mid-marker">
								<span class="asset-bar-mid-label">1億<br/>2028</span>
							</div>
							<div class="asset-bar-goal">2億</div>
						</div>
						<div class="asset-bar-scale">
							<span>0</span><span>5,000万</span><span>1億</span><span>1.5億</span><span>2億</span>
						</div>
					</div>
				</div>
				<div class="asset-chart-wrap">
					<img src="/images/nomura-asset-chart.png" alt="野村証券 資産推移チャート（2025年3月〜2026年4月）" class="asset-chart-img" />
				</div>
				<p class="asset-update-rule">📅 資産推移は毎月第1営業日に更新します。</p>
				<p class="asset-disclaimer">※ 野村証券の実口座。投資勧誘ではありません。</p>
			</section>

			<section class="watchlist">
				<div class="watchlist-header">
					<span class="watchlist-title">📋 紹介銘柄 現況レポート</span>
					<span class="watchlist-updated">2026年5月更新</span>
				</div>
				<div class="watchlist-rows">
					<a href="/blog/tobu-network-9036/" class="wl-row">
						<span class="wl-rating rA-plus">A<sup>+</sup></span>
						<span class="wl-name">東部ネットワーク <span class="wl-code">9036</span></span>
						<span class="wl-status"><span class="wl-dot green"></span>継続強気ホールド — 基本出口まで保有</span>
						<span class="wl-arrow">→</span>
					</a>
					<a href="/blog/shinyei-3004/" class="wl-row">
						<span class="wl-rating rA">A</span>
						<span class="wl-name">神栄 <span class="wl-code">3004</span></span>
						<span class="wl-status"><span class="wl-dot yellow"></span>依然割安継続 — 下がればロット追加検討</span>
						<span class="wl-arrow">→</span>
					</a>
				</div>
			</section>

			<div class="method-note">
				<span class="method-icon">🤖</span>
				<div>
					<p>掲載している「期待株価」は、複数AIによるベア・ベース・ブル3ケースの確率加重平均です。参考値であり投資勧誘ではありません。 <a href="/about#分析スタンス">詳しくはAboutへ →</a></p>
					<p>不動産含み益の計算は、有価証券報告書に記載の具体的な物件情報と取得時期をもとにAIによる公示価格分析をパワープレイで実行して算出しています。ブレはあるかもですがそこまで変な予測にはなっていないはずです。</p>
				</div>
			</div>

			<section class="posts-section">
				<h2>最新記事</h2>
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="post-title">{post.data.title}</span>
								<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							</a>
						</li>
					))}
				</ul>
				<a href="/blog" class="all-posts-link">すべての記事を見る →</a>
			</section>

			<section class="members-teaser">
				<h2>メンバー紹介</h2>
				<p>バリュー商会には個性豊かな動物担当たちがいます。</p>
				<div class="member-emojis">
					<span title="待伏 静江（TOB担当）">🐊</span>
					<span title="河内 拾造（低PBR担当）">🦦</span>
					<span title="堀田 独占（競合優位性担当）">🦫</span>
					<span title="夜見 賢三（財務分析担当）">🦉</span>
					<span title="優田 雅代（株主優待担当）">🦩</span>
					<span title="花岡 利次郎（高配当担当）">🐝</span>
					<span title="守田 退三（リスク管理担当）">🦞</span>
					<span title="墨田 検二（AIバックチェック担当）">🦑</span>
				</div>
				<a href="/characters" class="all-posts-link">メンバー一覧を見る →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* ── Asset Status ── */
	.asset-status {
		background: linear-gradient(135deg, #1a3a1c 0%, #0f2610 100%);
		border-radius: 12px;
		padding: 1.4em 1.5em;
		margin-bottom: 2em;
		color: #fff;
		position: relative;
		overflow: hidden;
	}
	.asset-status::before {
		content: '📈';
		position: absolute;
		right: -10px;
		bottom: -15px;
		font-size: 7em;
		opacity: 0.05;
		line-height: 1;
		pointer-events: none;
	}
	.asset-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.1em;
		flex-wrap: wrap;
		gap: 0.4em;
	}
	.asset-launch-badge {
		background: rgba(126,217,87,0.18);
		border: 1px solid rgba(126,217,87,0.4);
		color: #a0e870;
		font-size: 0.72em;
		font-weight: 700;
		padding: 0.25em 0.8em;
		border-radius: 999px;
		letter-spacing: 0.04em;
	}
	.asset-account {
		font-size: 0.68em;
		color: rgba(255,255,255,0.4);
		font-weight: 600;
		letter-spacing: 0.06em;
	}
	.asset-main { margin-bottom: 1.2em; }
	.asset-amounts {
		display: flex;
		align-items: center;
		gap: 0;
		margin-bottom: 0.9em;
	}
	.asset-amt-block {
		flex: 1;
		min-width: 0;
	}
	.asset-amt-arrow {
		flex: 0 0 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0 2px;
	}
	.asset-amt-label {
		font-size: 0.6em;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(255,255,255,0.45);
		margin-bottom: 0.2em;
		white-space: nowrap;
	}
	.asset-amt-val { font-size: 1.05em; color: #fff; }
	.asset-amt-val strong { font-size: 1.35em; }
	.val-now strong  { color: #7ed957; }
	.val-mid strong  { color: #a0c8ff; }
	.val-goal strong { color: #e8b84b; }
	.asset-bar-wrap { }
	.asset-bar {
		background: rgba(255,255,255,0.1);
		border-radius: 6px;
		height: 28px;
		position: relative;
		overflow: visible;
		margin-bottom: 0.35em;
	}
	.asset-bar-fill {
		width: 25%;
		height: 100%;
		background: linear-gradient(90deg, #2c7a2e, #7ed957);
		border-radius: 6px;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: flex-end;
	}
	.asset-bar-now {
		position: absolute;
		right: -30px;
		top: -2px;
		font-size: 0.5em;
		font-weight: 700;
		color: #7ed957;
		text-align: center;
		line-height: 1.2;
		white-space: nowrap;
	}
	.asset-bar-mid-marker {
		position: absolute;
		left: 50%;
		top: 0;
		height: 100%;
		width: 1px;
		background: rgba(160,200,255,0.45);
		pointer-events: none;
	}
	.asset-bar-mid-label {
		position: absolute;
		left: 4px;
		top: -1px;
		font-size: 0.48em;
		font-weight: 700;
		color: #a0c8ff;
		text-align: center;
		line-height: 1.2;
		white-space: nowrap;
	}
	.asset-bar-goal {
		position: absolute;
		right: 6px;
		top: 50%;
		transform: translateY(-50%);
		font-size: 0.6em;
		font-weight: 700;
		color: rgba(255,255,255,0.4);
	}
	.asset-bar-scale {
		display: flex;
		justify-content: space-between;
		font-size: 0.58em;
		color: rgba(255,255,255,0.3);
		padding: 0 2px;
	}
	.asset-now-sub { font-size: 0.72em; color: rgba(255,255,255,0.5); margin-top: 0.15em; }
	.asset-now-sub .pos { color: #7ed957; font-weight: 700; }
	.asset-chart-wrap {
		margin: 1em 0;
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid rgba(255,255,255,0.1);
	}
	.asset-chart-img {
		width: 100%;
		display: block;
		border-radius: 0;
	}
	.asset-update-rule {
		font-size: 0.68em;
		color: rgba(255,255,255,0.45);
		margin: 0.6em 0 0.3em;
		padding-top: 0.7em;
		border-top: 1px solid rgba(255,255,255,0.1);
	}
	.asset-disclaimer {
		font-size: 0.65em;
		color: rgba(255,255,255,0.3);
		margin: 0;
		line-height: 1.5;
	}
	/* ── Watchlist ── */
	.watchlist {
		margin-bottom: 2em;
		border: 1px solid #dde3ec;
		border-radius: 10px;
		overflow: hidden;
	}
	.watchlist-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.55em 1em;
		background: #f0f4f0;
		border-bottom: 1px solid #dde3ec;
	}
	.watchlist-title {
		font-size: 0.78em;
		font-weight: 700;
		color: var(--accent-dark);
		letter-spacing: 0.04em;
	}
	.watchlist-updated {
		font-size: 0.65em;
		color: rgb(var(--gray));
	}
	.watchlist-rows { display: flex; flex-direction: column; }
	.wl-row {
		display: flex;
		align-items: center;
		gap: 0.75em;
		padding: 0.7em 1em;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		border-bottom: 1px solid #f0f2f5;
		transition: background 0.12s;
		flex-wrap: wrap;
	}
	.wl-row:last-child { border-bottom: none; }
	.wl-row:hover { background: #f5faf5; }
	.wl-rating {
		font-size: 0.78em;
		font-weight: 800;
		min-width: 2.4em;
		text-align: center;
		padding: 0.15em 0.5em;
		border-radius: 4px;
		flex-shrink: 0;
		letter-spacing: 0.02em;
	}
	.wl-rating sup { font-size: 0.7em; }
	.rA-plus { background: #fff4cc; color: #8a6a00; border: 1px solid #e8c840; }
	.rA      { background: #e6f5ee; color: var(--accent-dark); border: 1px solid #a8d8bc; }
	.wl-name {
		font-size: 0.85em;
		font-weight: 700;
		min-width: 120px;
		flex-shrink: 0;
	}
	.wl-code {
		font-size: 0.8em;
		font-weight: 400;
		color: rgb(var(--gray));
		margin-left: 0.3em;
	}
	.wl-status {
		font-size: 0.82em;
		color: rgb(var(--gray-dark));
		flex: 1;
		display: flex;
		align-items: center;
		gap: 0.45em;
	}
	.wl-dot {
		width: 7px; height: 7px;
		border-radius: 50%;
