---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 5);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-badge">🏢 バリュー商会</div>
				<h1>沼田課長と愉快な部下たちの<br />投資記録</h1>
				<p class="hero-desc">{SITE_DESCRIPTION}</p>
				<div class="hero-tags">
					<span class="tag">割安日本個別株</span>
					<span class="tag">TOB発掘</span>
					<span class="tag">低PBR</span>
					<span class="tag">高配当・優待</span>
					<span class="tag">ガバナンス改革</span>
				</div>
			</section>

			<section class="about-blog">
				<h2>バリュー商会とは</h2>
				<div class="about-grid">
					<div class="about-item">
						<span class="about-icon">🧑‍💼</span>
						<div>
							<div class="about-label">運営者</div>
							<div class="about-text">保有資産約5,000万円。野村の錬金術士（見習い）こと沼田堅一課長を主人公に、バリュー商会の資産を実際の投資成績と直結させて育てていく実践記録です。</div>
						</div>
					</div>
					<div class="about-item">
						<span class="about-icon">🎯</span>
						<div>
							<div class="about-label">目標</div>
							<div class="about-text"><strong>バリュー商会の資産推移＝筆者本人の運用成績です。</strong>2030年までに2億円以上を目指します。<br /><span class="about-note-inline">※注目銘柄は紹介しますがポジション全部の公開はしてません。インデックスやテーマ株・モメンタムも時々混ざるのでブレは多少あります。</span></div>
						</div>
					</div>
					<div class="about-item">
						<span class="about-icon">📊</span>
						<div>
							<div class="about-label">投資スタンス</div>
							<div class="about-text">メインはバリュー株・TOB発掘・低PBR。サテライトでテーマ株やテクニカルトレードも実践勉強中なので結構勝手に動きます。紹介銘柄・戦略は野村証券の口座で実際に売買しながら更新します。</div>
						</div>
					</div>
				</div>
				<p class="about-note">※このブログは自身の投資手法や成績を振り返り、今後に活かす場所として活用しています。</p>
			</section>

			<section class="asset-status">
				<div class="asset-header">
					<span class="asset-launch-badge">🚀 スタートライン — 2026年5月</span>
					<span class="asset-account">野村証券 実口座</span>
				</div>
				<div class="asset-main">
					<div class="asset-amounts">
						<div class="asset-now-block">
							<div class="asset-now-label">現在総資産（2026年5月）</div>
							<div class="asset-now-val"><strong>4,474万円</strong></div>
							<div class="asset-now-sub">評価損益 <span class="pos">+816万円</span></div>
						</div>
						<div class="asset-arrow-block">
							<svg viewBox="0 0 60 20" class="asset-arrow-svg"><path d="M0 10 L48 10 M40 4 L52 10 L40 16" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
						</div>
						<div class="asset-goal-block">
							<div class="asset-goal-label">2030年末 目標</div>
							<div class="asset-goal-val"><strong>2億円</strong></div>
						</div>
					</div>
					<div class="asset-bar-wrap">
						<div class="asset-bar">
							<div class="asset-bar-fill" style="width:22.4%">
								<span class="asset-bar-now">NOW<br/>22%</span>
							</div>
							<div class="asset-bar-goal">2億</div>
						</div>
						<div class="asset-bar-scale">
							<span>0</span><span>5,000万</span><span>1億</span><span>1.5億</span><span>2億</span>
						</div>
					</div>
				</div>
				<div class="asset-chart-wrap">
					<img src="/images/nomura-asset-chart.png" alt="野村証券 資産推移チャート（2025年3月〜2026年4月）" class="asset-chart-img" />
				</div>
				<p class="asset-update-rule">📅 資産推移は毎月第1営業日に更新します。</p>
				<p class="asset-disclaimer">※ 野村証券の実口座。投資勧誘ではありません。</p>
			</section>

			<div class="method-note">
				<span class="method-icon">🤖</span>
				<div>
					<p>掲載している「期待株価」は、複数AIによるベア・ベース・ブル3ケースの確率加重平均です。参考値であり投資勧誘ではありません。 <a href="/about#分析スタンス">詳しくはAboutへ →</a></p>
					<p>不動産含み益の計算は、有価証券報告書に記載の具体的な物件情報と取得時期をもとにAIによる公示価格分析をパワープレイで実行して算出しています。ブレはあるかもですがそこまで変な予測にはなっていないはずです。</p>
				</div>
			</div>

			<section class="posts-section">
				<h2>最新記事</h2>
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="post-title">{post.data.title}</span>
								<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							</a>
						</li>
					))}
				</ul>
				<a href="/blog" class="all-posts-link">すべての記事を見る →</a>
			</section>

			<section class="members-teaser">
				<h2>メンバー紹介</h2>
				<p>バリュー商会には個性豊かな動物担当たちがいます。</p>
				<div class="member-emojis">
					<span title="待伏 静江（TOB担当）">🐊</span>
					<span title="河内 拾造（低PBR担当）">🦦</span>
					<span title="堀田 独占（競合優位性担当）">🦫</span>
					<span title="夜見 賢三（財務分析担当）">🦉</span>
					<span title="優田 雅代（株主優待担当）">🦩</span>
					<span title="花岡 利次郎（高配当担当）">🐝</span>
					<span title="守田 退三（リスク管理担当）">🦞</span>
					<span title="墨田 検二（AIバックチェック担当）">🦑</span>
				</div>
				<a href="/characters" class="all-posts-link">メンバー一覧を見る →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* ── Asset Status ── */
	.asset-status {
		background: linear-gradient(135deg, #1a3a1c 0%, #0f2610 100%);
		border-radius: 12px;
		padding: 1.4em 1.5em;
		margin-bottom: 2em;
		color: #fff;
		position: relative;
		overflow: hidden;
	}
	.asset-status::before {
		content: '📈';
		position: absolute;
		right: -10px;
		bottom: -15px;
		font-size: 7em;
		opacity: 0.05;
		line-height: 1;
		pointer-events: none;
	}
	.asset-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.1em;
		flex-wrap: wrap;
		gap: 0.4em;
	}
	.asset-launch-badge {
		background: rgba(126,217,87,0.18);
		border: 1px solid rgba(126,217,87,0.4);
		color: #a0e870;
		font-size: 0.72em;
		font-weight: 700;
		padding: 0.25em 0.8em;
		border-radius: 999px;
		letter-spacing: 0.04em;
	}
	.asset-account {
		font-size: 0.68em;
		color: rgba(255,255,255,0.4);
		font-weight: 600;
		letter-spacing: 0.06em;
	}
	.asset-main { margin-bottom: 1.2em; }
	.asset-amounts {
		display: flex;
		align-items: center;
		gap: 1em;
		margin-bottom: 0.9em;
		flex-wrap: wrap;
	}
	.asset-now-label, .asset-goal-label {
		font-size: 0.62em;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: rgba(255,255,255,0.45);
		margin-bottom: 0.2em;
	}
	.asset-now-val {
		font-size: 1.05em;
		color: #fff;
	}
	.asset-now-val strong { font-size: 1.35em; color: #7ed957; }
	.asset-goal-val { font-size: 1.05em; color: #fff; }
	.asset-goal-val strong { font-size: 1.35em; color: #e8b84b; }
	.asset-arrow-block { flex: 1; min-width: 40px; max-width: 80px; }
	.asset-arrow-svg { width: 100%; color: rgba(255,255,255,0.3); }
	.asset-bar-wrap { }
	.asset-bar {
		background: rgba(255,255,255,0.1);
		border-radius: 6px;
		height: 28px;
		position: relative;
		overflow: visible;
		margin-bottom: 0.35em;
	}
	.asset-bar-fill {
		width: 25%;
		height: 100%;
		background: linear-gradient(90deg, #2c7a2e, #7ed957);
		border-radius: 6px;
		position: relative;
		display: flex;
		align-items: center;
		justify-content: flex-end;
	}
	.asset-bar-now {
		position: absolute;
		right: -30px;
		top: -2px;
		font-size: 0.5em;
		font-weight: 700;
		color: #7ed957;
		text-align: center;
		line-height: 1.2;
		white-space: nowrap;
	}
	.asset-bar-goal {
		position: absolute;
		right: 6px;
		top: 50%;
		transform: translateY(-50%);
		font-size: 0.6em;
		font-weight: 700;
		color: rgba(255,255,255,0.4);
	}
	.asset-bar-scale {
		display: flex;
		justify-content: space-between;
		font-size: 0.58em;
		color: rgba(255,255,255,0.3);
		padding: 0 2px;
	}
	.asset-now-sub { font-size: 0.72em; color: rgba(255,255,255,0.5); margin-top: 0.15em; }
	.asset-now-sub .pos { color: #7ed957; font-weight: 700; }
	.asset-chart-wrap {
		margin: 1em 0;
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid rgba(255,255,255,0.1);
	}
	.asset-chart-img {
		width: 100%;
		display: block;
		border-radius: 0;
	}
	.asset-update-rule {
		font-size: 0.68em;
		color: rgba(255,255,255,0.45);
		margin: 0.6em 0 0.3em;
		padding-top: 0.7em;
		border-top: 1px solid rgba(255,255,255,0.1);
	}
	.asset-disclaimer {
		font-size: 0.65em;
		color: rgba(255,255,255,0.3);
		margin: 0;
		line-height: 1.5;
	}
	/* ── About Blog ── */
	.about-blog {
		margin-bottom: 2.5em;
		padding: 1.4em 1.2em;
		background: #f8faf8;
		border: 1px solid #dde8dd;
		border-radius: 10px;
	}
	.about-blog h2 {
		font-size: 1.1em;
		color: var(--accent-dark);
		border-left: 4px solid var(--accent);
		padding-left: 0.6em;
		margin: 0 0 1em;
	}
	.about-grid {
		display: flex;
		flex-direction: column;
		gap: 0.85em;
		margin-bottom: 0.9em;
	}
	.about-item {
		display: flex;
		gap: 0.75em;
		align-items: flex-start;
	}
	.about-icon {
		font-size: 1.3em;
		flex-shrink: 0;
		margin-top: 0.05em;
	}
	.about-label {
		font-size: 0.7em;
		font-weight: 700;
		letter-spacing: 0.08em;
		color: var(--accent-dark);
		text-transform: uppercase;
		margin-bottom: 0.2em;
	}
	.about-text {
		font-size: 0.85em;
		color: rgb(var(--gray-dark));
		line-height: 1.65;
	}
	.about-note-inline {
		font-size: 0.9em;
		color: rgb(var(--gray));
		display: block;
		margin-top: 0.4em;
		line-height: 1.6;
	}
	.about-note {
		font-size: 0.76em;
		color: rgb(var(--gray));
		margin: 0;
		padding-top: 0.8em;
		border-top: 1px dashed #ccd8cc;
	}
	.hero {
		text-align: center;
		padding: 3em 1em 2em;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2em;
	}
	.hero-badge {
		display: inline-block;
		background: var(--accent-light);
		color: var(--accent-dark);
		font-weight: bold;
		font-size: 0.85em;
		padding: 0.3em 1em;
		border-radius: 999px;
		margin-bottom: 1em;
	}
	.hero h1 {
		font-size: 2em;
		line-height: 1.4;
		margin-bottom: 0.6em;
	}
	.hero-desc {
		color: rgb(var(--gray));
		font-size: 0.95em;
		max-width: 560px;
		margin: 0 auto 1.5em;
		line-height: 1.8;
	}
	.hero-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		justify-content: center;
	}
	.tag {
		background: var(--accent-light);
		color: var(--accent-dark);
		font-size: 0.8em;
		padding: 0.2em 0.8em;
		border-radius: 4px;
		font-weight: 600;
	}
	.method-note {
		display: flex;
		gap: 0.6em;
		align-items: flex-start;
		background: #f4f6f9;
		border: 1px solid #dde1e8;
		border-left: 3px solid var(--accent);
		border-radius: 6px;
		padding: 0.65em 0.9em;
		margin-bottom: 2em;
		font-size: 0.82em;
		color: rgb(var(--gray-dark));
		line-height: 1.6;
	}
	.method-icon { font-size: 1.1em; flex-shrink: 0; margin-top: 0.1em; }
	.method-note p { margin: 0; }
	.method-note a { color: var(--accent); text-decoration: none; font-weight: 600; }
	.method-note a:hover { color: var(--accent-dark); }

	.posts-section, .members-teaser {
		margin-bottom: 3em;
	}
	h2 {
		font-size: 1.3em;
		color: var(--accent-dark);
		border-left: 4px solid var(--accent);
		padding-left: 0.6em;
		margin-bottom: 1em;
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1em;
	}
	.post-list li {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.post-list a {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.8em 0.4em;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		gap: 1em;
	}
	.post-list a:hover {
		color: var(--accent-dark);
	}
	.post-title {
		flex: 1;
	}
	.post-date {
		font-size: 0.8em;
		color: rgb(var(--gray));
		white-space: nowrap;
	}
	.all-posts-link {
		display: inline-block;
		color: var(--accent);
		font-weight: 600;
		text-decoration: none;
		font-size: 0.95em;
	}
	.all-posts-link:hover {
		color: var(--accent-dark);
	}
	.member-emojis {
		display: flex;
		gap: 0.8em;
		flex-wrap: wrap;
		font-size: 2.5em;
		margin: 0.5em 0 1em;
	}
	.member-emojis span {
		cursor: default;
	}
	@media (max-width: 720px) {
		.hero h1 {
			font-size: 1.5em;
		}
		.post-list a {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.2em;
		}
	}
</style>
