---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 5);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-badge">🏢 バリュー商会</div>
				<h1>沼田課長と愉快な部下たちの<br />投資記録</h1>
				<p class="hero-desc">{SITE_DESCRIPTION}</p>
				<div class="hero-tags">
					<span class="tag">割安日本個別株</span>
					<span class="tag">TOB発掘</span>
					<span class="tag">低PBR</span>
					<span class="tag">高配当・優待</span>
					<span class="tag">ガバナンス改革</span>
				</div>
			</section>

			<section class="posts-section">
				<h2>最新記事</h2>
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<span class="post-title">{post.data.title}</span>
								<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							</a>
						</li>
					))}
				</ul>
				<a href="/blog" class="all-posts-link">すべての記事を見る →</a>
			</section>

			<section class="members-teaser">
				<h2>メンバー紹介</h2>
				<p>バリュー商会には個性豊かな動物担当たちがいます。</p>
				<div class="member-emojis">
					<span title="待伏 静江（TOB担当）">🐊</span>
					<span title="河内 拾造（低PBR担当）">🦦</span>
					<span title="堀田 独占（競合優位性担当）">🦫</span>
					<span title="夜見 賢三（財務分析担当）">🦉</span>
					<span title="優田 雅代（株主優待担当）">🦩</span>
					<span title="花岡 利次郎（高配当担当）">🐝</span>
					<span title="守田 退三（リスク管理担当）">🦞</span>
					<span title="墨田 検二（AIバックチェック担当）">🦑</span>
				</div>
				<a href="/characters" class="all-posts-link">メンバー一覧を見る →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		padding: 3em 1em 2em;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 2em;
	}
	.hero-badge {
		display: inline-block;
		background: var(--accent-light);
		color: var(--accent-dark);
		font-weight: bold;
		font-size: 0.85em;
		padding: 0.3em 1em;
		border-radius: 999px;
		margin-bottom: 1em;
	}
	.hero h1 {
		font-size: 2em;
		line-height: 1.4;
		margin-bottom: 0.6em;
	}
	.hero-desc {
		color: rgb(var(--gray));
		font-size: 0.95em;
		max-width: 560px;
		margin: 0 auto 1.5em;
		line-height: 1.8;
	}
	.hero-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
		justify-content: center;
	}
	.tag {
		background: var(--accent-light);
		color: var(--accent-dark);
		font-size: 0.8em;
		padding: 0.2em 0.8em;
		border-radius: 4px;
		font-weight: 600;
	}
	.posts-section, .members-teaser {
		margin-bottom: 3em;
	}
	h2 {
		font-size: 1.3em;
		color: var(--accent-dark);
		border-left: 4px solid var(--accent);
		padding-left: 0.6em;
		margin-bottom: 1em;
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1em;
	}
	.post-list li {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.post-list a {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.8em 0.4em;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		gap: 1em;
	}
	.post-list a:hover {
		color: var(--accent-dark);
	}
	.post-title {
		flex: 1;
	}
	.post-date {
		font-size: 0.8em;
		color: rgb(var(--gray));
		white-space: nowrap;
	}
	.all-posts-link {
		display: inline-block;
		color: var(--accent);
		font-weight: 600;
		text-decoration: none;
		font-size: 0.95em;
	}
	.all-posts-link:hover {
		color: var(--accent-dark);
	}
	.member-emojis {
		display: flex;
		gap: 0.8em;
		flex-wrap: wrap;
		font-size: 2.5em;
		margin: 0.5em 0 1em;
	}
	.member-emojis span {
		cursor: default;
	}
	@media (max-width: 720px) {
		.hero h1 {
			font-size: 1.5em;
		}
		.post-list a {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.2em;
		}
	}
</style>
