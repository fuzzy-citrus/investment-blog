---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { characters, rivalOrgs, teamLabels } from '../data/characters';

const founder  = characters.filter(c => c.team === 'founder');
const manager  = characters.filter(c => c.team === 'manager');
const teamA    = characters.filter(c => c.team === 'teamA');
const teamB    = characters.filter(c => c.team === 'teamB');
const cross    = characters.filter(c => c.team === 'cross');

const sections = [
  { key: 'founder', icon: '🏛️', label: teamLabels['founder'], members: founder },
  { key: 'manager', icon: '📋', label: teamLabels['manager'], members: manager },
  { key: 'teamA',   icon: '📊', label: teamLabels['teamA'],   members: teamA  },
  { key: 'teamB',   icon: '💴', label: teamLabels['teamB'],   members: teamB  },
  { key: 'cross',   icon: '🔍', label: teamLabels['cross'],   members: cross  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title="メンバー一覧 | バリュー商会" description="バリュー商会の投資担当メンバー紹介" />
  </head>
  <body>
    <Header />
    <main>
      <div class="page-header">
        <h1>メンバー一覧</h1>
        <p class="lead">バリュー商会の投資担当たちをご紹介します。</p>
        <a href="/org" class="org-link">🗂 組織図で見る →</a>
      </div>

      {sections.map(sec => (
        <section class="team-section">
          <h2 class="team-heading">
            <span class="team-icon">{sec.icon}</span>
            {sec.label}
          </h2>

          {sec.members.map(c => (
            <div class="char-card" id={c.id} style={`--card-color: ${c.avatarColor}`}>

              {/* ── ヘッダー行 ── */}
              <div class="char-header">
                <div class="char-avatar" style={`background: ${c.avatarColor}`}>
                  {c.emoji}
                </div>
                <div class="char-info">
                  <div class="char-role">{c.title}</div>
                  <h3 class="char-name">
                    {c.name}
                    <span class="char-reading">（{c.reading}）</span>
                  </h3>
                  <p class="char-species">{c.species}</p>
                  <blockquote class="char-quote">「{c.quote}」</blockquote>
                  <div class="char-tags">
                    {c.tags.map(t => <span class="tag">{t}</span>)}
                  </div>
                </div>
              </div>

              {/* ── キャラクター像 ── */}
              <div class="char-body">
                <div class="section-label">キャラクター像</div>
                <p class="char-desc">{c.description}</p>

                <div class="section-label relation-label">沼田課長・チームとの関係性</div>
                <p class="char-relation">{c.relation}</p>

                {/* ── 分析フレーム ── */}
                <div class="section-label">得意な分析フレーム</div>
                <div class={`frames-grid frames-${c.analysisFrames.length}`}>
                  {c.analysisFrames.map(f => (
                    <div class="frame-card">
                      <div class="frame-title">{f.icon} {f.title}</div>
                      <p class="frame-body">{f.body}</p>
                    </div>
                  ))}
                </div>
              </div>

            </div>
          ))}
        </section>
      ))}

      {/* ── ライバル陣営 ── */}
      <section class="rival-outer">
        <h2 class="team-heading rival-heading">⚔️ ライバル陣営</h2>
        <p class="rival-intro">
          彼らはかつての自分の一面であり、良さを認めたうえで超えていくべき好敵手。
        </p>

        {rivalOrgs.map(org => (
          <div class="rival-org">

            {/* 組織ヘッダー */}
            <div class="rival-org-header">
              <div class="rival-org-title-row">
                <span class="rival-org-emoji">{org.emoji}</span>
                <div>
                  <div class="rival-org-name">{org.name}　{org.subtitle}</div>
                  <div class="rival-org-tagline">{org.tagline}</div>
                </div>
              </div>
              <div class="rival-org-meta">
                <div class="rival-meta-item past-self">
                  <span class="rival-meta-label">🪞 過去の自分として</span>
                  <p>{org.pastSelf}</p>
                </div>
                <div class="rival-org-sub-grid">
                  <div class="rival-meta-item">
                    <span class="rival-meta-label">👍 認める良さ</span>
                    <p>{org.respects}</p>
                  </div>
                  <div class="rival-meta-item">
                    <span class="rival-meta-label">🎯 超えるべき点</span>
                    <p>{org.toSurpass}</p>
                  </div>
                </div>
              </div>
            </div>

            {/* メンバーカード */}
            <div class="rival-members-grid">
              {org.members.map(m => (
                <div class="rival-member-card" style={`background: ${m.avatarColor}`}>
                  <div class="rival-mc-header">
                    <div class="rival-mc-avatar" style="background: white">{m.emoji}</div>
                    <div>
                      <div class="rival-mc-title">{m.title}</div>
                      <div class="rival-mc-name">{m.name}
                        <span class="rival-mc-reading">（{m.reading}）</span>
                      </div>
                      <div class="rival-mc-quote">「{m.quote}」</div>
                    </div>
                  </div>
                  <p class="rival-mc-desc">{m.description}</p>
                  <div class="rival-mc-tags">
                    {m.tags.map(t => <span class="rival-tag">{t}</span>)}
                  </div>
                  <div class="rival-mc-speech-block">
                    <div class="speech-label">口調サンプル</div>
                    <blockquote class="rival-mc-speech">「{m.speechSample}」</blockquote>
                    <p class="rival-mc-numata">沼田さん：「{m.numataReaction}」</p>
                  </div>
                </div>
              ))}
            </div>

          </div>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 2.5em 1em 4em;
  }

  .page-header { margin-bottom: 2.5em; }
  .page-header h1 {
    font-size: 1.6em;
    color: var(--accent-dark);
    margin-bottom: 0.2em;
  }
  .lead { color: rgb(var(--gray)); font-size: 0.9em; margin-bottom: 0.6em; }
  .org-link {
    display: inline-block;
    font-size: 0.85em;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 0.2em 0.7em;
    margin-top: 0.3em;
  }
  .org-link:hover { background: var(--accent-light); }

  /* チームセクション */
  .team-section { margin-bottom: 3em; }
  .team-heading {
    font-size: 1.05em;
    font-weight: 700;
    color: var(--accent-dark);
    border-left: 4px solid var(--accent);
    padding-left: 0.6em;
    margin-bottom: 1em;
    display: flex;
    align-items: center;
    gap: 0.4em;
  }
  .rival-heading {
    border-left-color: #aaa;
    color: rgb(var(--gray-dark));
  }
  .team-icon { font-size: 1em; }

  /* キャラクターカード */
  .char-card {
    background: white;
    border: 1.5px solid #e8e8e8;
    border-top: 3px solid var(--accent);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 1.2em;
    box-shadow: 0 1px 4px rgba(0,0,0,5%);
  }

  /* ヘッダー行 */
  .char-header {
    display: flex;
    gap: 1.2em;
    align-items: flex-start;
    padding: 1.2em 1.4em 1em;
    background: var(--card-color, #f5fdf8);
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .char-avatar {
    font-size: 2.2em;
    width: 2em;
    height: 2em;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: white;
    box-shadow: 0 1px 4px rgba(0,0,0,12%);
    flex-shrink: 0;
  }
  .char-info { flex: 1; min-width: 0; }
  .char-role {
    font-size: 0.68em;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--accent-dark);
    margin-bottom: 0.15em;
    text-transform: uppercase;
  }
  .char-name {
    font-size: 1.15em;
    font-weight: 700;
    color: rgb(var(--black));
    margin: 0 0 0.1em;
    line-height: 1.3;
  }
  .char-reading {
    font-size: 0.7em;
    font-weight: 400;
    color: rgb(var(--gray));
  }
  .char-species {
    font-size: 0.78em;
    color: rgb(var(--gray));
    margin: 0 0 0.5em;
  }
  .char-quote {
    border-left: 3px solid var(--accent);
    padding: 0.2em 0 0.2em 0.7em;
    margin: 0 0 0.6em;
    font-size: 0.83em;
    font-style: italic;
    color: rgb(var(--gray-dark));
    line-height: 1.5;
  }
  .char-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3em;
  }
  .tag {
    background: white;
    color: var(--accent-dark);
    font-size: 0.68em;
    padding: 0.15em 0.55em;
    border-radius: 4px;
    font-weight: 600;
    border: 1px solid var(--accent);
  }

  /* ボディ */
  .char-body {
    padding: 1em 1.4em 1.2em;
  }
  .section-label {
    font-size: 0.65em;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--gray));
    margin-bottom: 0.4em;
    margin-top: 1em;
  }
  .char-body .section-label:first-child { margin-top: 0; }
  .char-desc {
    font-size: 0.85em;
    color: rgb(var(--gray-dark));
    line-height: 1.75;
    margin: 0;
  }
  .relation-label { color: var(--accent-dark); }
  .char-relation {
    font-size: 0.82em;
    color: rgb(var(--gray));
    line-height: 1.7;
    margin: 0;
    font-style: italic;
    border-left: 2px solid rgb(var(--gray-light));
    padding-left: 0.7em;
  }

  /* 分析フレームグリッド */
  .frames-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6em;
    margin-top: 0.2em;
  }
  .frames-1 { grid-template-columns: 1fr; }
  .frames-3 { grid-template-columns: 1fr 1fr; }

  .frame-card {
    background: #f7f9fc;
    border: 1px solid #e8edf2;
    border-radius: 7px;
    padding: 0.7em 0.9em;
  }
  .frame-title {
    font-size: 0.78em;
    font-weight: 700;
    color: rgb(var(--black));
    margin-bottom: 0.35em;
  }
  .frame-body {
    font-size: 0.76em;
    color: rgb(var(--gray-dark));
    line-height: 1.65;
    margin: 0;
  }

  /* ライバル陣営 */
  .rival-outer { margin-top: 1em; }
  .rival-heading {
    border-left-color: #999;
    color: rgb(var(--gray-dark));
  }
  .rival-intro {
    font-size: 0.85em;
    color: rgb(var(--gray));
    font-style: italic;
    margin: -0.5em 0 1.5em;
  }

  .rival-org {
    border: 2px dashed #ccc;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.8em;
  }

  /* 組織ヘッダー */
  .rival-org-header {
    background: #f4f6f9;
    padding: 1.2em 1.4em 1em;
    border-bottom: 1px solid #dde1e8;
  }
  .rival-org-title-row {
    display: flex;
    align-items: center;
    gap: 0.8em;
    margin-bottom: 1em;
  }
  .rival-org-emoji { font-size: 2.2em; }
  .rival-org-name {
    font-size: 1.05em;
    font-weight: 700;
    color: rgb(var(--black));
    line-height: 1.3;
  }
  .rival-org-tagline {
    font-size: 0.78em;
    color: rgb(var(--gray));
    font-style: italic;
    margin-top: 0.1em;
  }
  .rival-org-meta { display: flex; flex-direction: column; gap: 0.7em; }
  .rival-org-sub-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6em;
  }
  .rival-meta-item {
    background: white;
    border-radius: 7px;
    padding: 0.6em 0.8em;
    border: 1px solid #e4e8ef;
  }
  .rival-meta-item.past-self {
    border-left: 3px solid #9aa5c0;
  }
  .rival-meta-label {
    display: block;
    font-size: 0.65em;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #7a8499;
    margin-bottom: 0.3em;
  }
  .rival-meta-item p {
    font-size: 0.8em;
    color: rgb(var(--gray-dark));
    line-height: 1.65;
    margin: 0;
  }

  /* メンバーカードグリッド */
  .rival-members-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }
  .rival-member-card {
    padding: 1em 1.1em 1em;
    border-right: 1px solid rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    gap: 0.6em;
  }
  .rival-member-card:last-child { border-right: none; }

  .rival-mc-header {
    display: flex;
    gap: 0.7em;
    align-items: flex-start;
  }
  .rival-mc-avatar {
    font-size: 1.6em;
    width: 1.8em;
    height: 1.8em;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 1px 3px rgba(0,0,0,10%);
  }
  .rival-mc-title {
    font-size: 0.62em;
    font-weight: 700;
    color: #7a8499;
    margin-bottom: 0.1em;
    letter-spacing: 0.04em;
  }
  .rival-mc-name {
    font-size: 0.88em;
    font-weight: 700;
    color: rgb(var(--black));
    line-height: 1.3;
  }
  .rival-mc-reading {
    font-size: 0.78em;
    font-weight: 400;
    color: rgb(var(--gray));
  }
  .rival-mc-quote {
    font-size: 0.75em;
    color: rgb(var(--gray));
    font-style: italic;
    margin-top: 0.2em;
    line-height: 1.4;
  }
  .rival-mc-desc {
    font-size: 0.79em;
    color: rgb(var(--gray-dark));
    line-height: 1.7;
    margin: 0;
  }
  .rival-mc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25em;
  }
  .rival-tag {
    font-size: 0.65em;
    background: rgba(0,0,0,0.06);
    color: rgb(var(--gray-dark));
    padding: 0.15em 0.5em;
    border-radius: 3px;
    font-weight: 600;
  }
  .rival-mc-speech-block {
    background: rgba(255,255,255,0.65);
    border-radius: 6px;
    padding: 0.6em 0.75em;
    margin-top: auto;
  }
  .speech-label {
    font-size: 0.6em;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #9aa5c0;
    margin-bottom: 0.3em;
    text-transform: uppercase;
  }
  .rival-mc-speech {
    font-size: 0.78em;
    font-style: italic;
    color: rgb(var(--gray-dark));
    border-left: 2px solid #bbc3d4;
    padding-left: 0.6em;
    margin: 0 0 0.4em;
    line-height: 1.55;
  }
  .rival-mc-numata {
    font-size: 0.73em;
    color: rgb(var(--gray));
    font-style: italic;
    margin: 0;
    padding-left: 0.1em;
  }

  @media (max-width: 600px) {
    .char-header { flex-direction: column; gap: 0.8em; }
    .frames-grid { grid-template-columns: 1fr; }
    .rival-grid  { grid-template-columns: 1fr; }
  }
</style>
