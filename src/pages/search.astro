---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BookSidebar from '../components/BookSidebar.astro';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title="記事検索 | 沼底バリュー商会" description="沼底バリュー商会の記事を検索" />
		<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
		<style>
			main {
				max-width: 740px;
				margin: 0 auto;
				padding: 2.5em 1em 4em;
			}
			h1 {
				font-size: 1.4em;
				color: var(--accent-dark);
				border-left: 4px solid var(--accent);
				padding-left: 0.6em;
				margin-bottom: 1.5em;
			}
			#search {
				margin-bottom: 2em;
			}
			.search-unavailable {
				display: none;
				padding: 1em;
				background: #f8faf8;
				border: 1px solid #dde8dd;
				border-radius: 8px;
				font-size: 0.88em;
				color: rgb(96, 115, 159);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>🔍 記事検索</h1>
			<div id="search"></div>
			<p class="search-unavailable" id="search-unavailable">
				検索インデックスを読み込み中です。デプロイ済みのサイトでご利用ください。
			</p>
		</main>
		<Footer />
		<script is:inline>
			function initPagefind() {
				if (typeof PagefindUI !== 'undefined') {
					new PagefindUI({
						element: '#search',
						showImages: false,
						translations: {
							placeholder: '銘柄名・キーワードで検索...',
							zero_results: '「[SEARCH_TERM]」に一致する記事が見つかりませんでした',
						},
					});
				} else {
					document.getElementById('search-unavailable').style.display = 'block';
				}
			}

			var s = document.createElement('script');
			s.src = '/pagefind/pagefind-ui.js';
			s.onload = initPagefind;
			s.onerror = function() {
				document.getElementById('search-unavailable').style.display = 'block';
			};
			document.head.appendChild(s);
		</script>
		<BookSidebar />
	</body>
</html>
