---
interface Props {
	term?: string;
}
const { term } = Astro.props;
---

<div class="giscus-wrap">
	<script
		src="https://giscus.app/client.js"
		data-repo="fuzzy-citrus/investment-blog"
		data-repo-id="R_kgDOSlU3vQ"
		data-category="General"
		data-category-id="DIC_kwDOSlU3vc4C91ug"
		data-mapping={term ? "specific" : "pathname"}
		data-term={term ?? ""}
		data-strict="0"
		data-reactions-enabled="1"
		data-emit-metadata="0"
		data-input-position="top"
		data-theme="light"
		data-lang="ja"
		data-loading="lazy"
		crossorigin="anonymous"
		async
		is:inline
	></script>
</div>

<style>
	.giscus-wrap {
		margin-top: 2.5em;
		padding-top: 2em;
		border-top: 1px solid rgb(var(--gray-light));
	}
</style>
