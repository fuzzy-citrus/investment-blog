function shuffle(arr) {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function renderBook(b) {
  return `<a class="bs-book" href="${b.href}" rel="nofollow" target="_blank">
    <img class="bs-img" src="${b.img}" alt="${b.alt}">
    <span class="bs-title">${b.title}</span>
    <span class="bs-price">${b.price}</span>
    <span class="bs-cta">楽天市場で見る →</span>
  </a>`;
}

const priority = BOOKS.filter(b => b.priority);
const rest = shuffle(BOOKS.filter(b => !b.priority));
// わが投資術 固定 + ランダム5冊、合計6冊を3/3に分割
const pool = [...priority, ...rest].slice(0, 6);

const leftEl = document.getElementById('bs-left');
const rightEl = document.getElementById('bs-right');
if (leftEl) leftEl.insertAdjacentHTML('beforeend', pool.slice(0, 3).map(renderBook).join(''));
if (rightEl) rightEl.insertAdjacentHTML('beforeend', pool.slice(3, 6).map(renderBook).join(''));
